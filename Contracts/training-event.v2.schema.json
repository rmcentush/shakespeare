{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shakespeare.example/schemas/training-event.v2.json",
  "title": "Shakespeare service personalization event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "eventType",
    "recordedAt",
    "writerID",
    "documentID",
    "provider",
    "model",
    "source",
    "operationKind",
    "learningCategory",
    "decision",
    "instruction",
    "originalText",
    "proposedText",
    "finalText",
    "surroundingText",
    "rationale",
    "groupID",
    "contentHash",
    "consent",
    "provenance"
  ],
  "properties": {
    "schemaVersion": { "enum": [1, 2] },
    "id": { "type": "string", "minLength": 1, "maxLength": 200 },
    "eventType": { "enum": ["edit_decision", "edit_outcome", "document_snapshot"] },
    "recordedAt": { "type": "number", "exclusiveMinimum": 0 },
    "writerID": { "type": "string", "minLength": 1, "maxLength": 200 },
    "documentID": { "type": "string", "minLength": 1, "maxLength": 200 },
    "provider": { "type": "string", "minLength": 1, "maxLength": 100 },
    "model": { "type": "string", "minLength": 1, "maxLength": 300 },
    "source": { "type": "string", "minLength": 1, "maxLength": 100 },
    "operationKind": { "type": "string", "maxLength": 100 },
    "learningCategory": { "type": "string", "maxLength": 100 },
    "decision": { "type": "string", "maxLength": 100 },
    "instruction": { "type": "string", "maxLength": 20000 },
    "originalText": { "type": "string", "maxLength": 250000 },
    "proposedText": { "type": "string", "maxLength": 250000 },
    "finalText": { "type": ["string", "null"], "maxLength": 500000 },
    "surroundingText": { "type": "string", "maxLength": 250000 },
    "rationale": { "type": "string", "maxLength": 20000 },
    "groupID": { "type": "string", "maxLength": 200 },
    "contentHash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "consent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["collectionEnabled", "scope"],
      "properties": {
        "collectionEnabled": { "const": true },
        "scope": { "const": "service_personalization" }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["application", "applicationVersion", "capture"],
      "properties": {
        "application": { "type": "string", "minLength": 1, "maxLength": 100 },
        "applicationVersion": { "type": "string", "minLength": 1, "maxLength": 100 },
        "capture": { "type": "string", "minLength": 1, "maxLength": 100 }
      }
    },
    "parentEventID": { "type": ["string", "null"], "minLength": 1, "maxLength": 200 },
    "outcome": { "type": ["string", "null"], "maxLength": 100 },
    "confidence": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "trainingEligible": { "type": ["boolean", "null"] }
  },
  "allOf": [
    {
      "if": { "properties": { "eventType": { "const": "edit_outcome" } } },
      "then": {
        "properties": { "schemaVersion": { "const": 2 } },
        "required": ["parentEventID", "outcome", "confidence", "trainingEligible"]
      }
    }
  ]
}
