{
  "name": "shakespeare-download-site",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log wrangler dev",
    "build": "npm run lint && node --test tests/static-site.test.mjs",
    "start": "npm run dev",
    "test": "node --test tests/*.test.mjs",
    "verify-download": "node --test tests/download-artifact.test.mjs",
    "lint": "node --check worker/index.js && node --check tests/static-site.test.mjs && node --check tests/download-artifact.test.mjs"
  },
  "devDependencies": {
    "wrangler": "4.92.0"
  },
  "type": "module"
}
